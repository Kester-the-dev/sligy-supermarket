# Copy this file to .env and fill in your SMTP provider settings.
# Supported values for EMAIL_HOST, EMAIL_PORT, EMAIL_SECURE, EMAIL_USER, EMAIL_PASS.

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_smtp_username
EMAIL_PASS=your_smtp_password
EMAIL_FROM="Sligy <no-reply@sligy.com>"

# If you prefer sendmail instead of SMTP, leave EMAIL_HOST empty and provide:
# SENDMAIL_PATH=/usr/sbin/sendmail
